# Rails — environment template. Copy to .env (gitignored); never commit real secrets.
# Network blocks are tagged [testnet] / [mainnet]; testnet is active by default.

# ── Server ──
SECRET=                                # 32-byte secret (AES + HMAC): openssl rand -hex 32
DEBUG=true
SERVER_HOST=0.0.0.0
SERVER_PORT=8000                       # ignored when the platform injects PORT
SERVER_TIMEZONE=Africa/Lagos
ALLOWED_HOSTS=*
TRUSTED_PROXIES=*                       # CIDRs gin trusts for X-Forwarded-For; * = trust all (PaaS edge)
ENVIRONMENT=local                      # local | staging | production
HOST_DOMAIN=http://localhost:8000
SENTRY_DSN=

# ── Auth / JWT ──
JWT_SIGNING_KEY=                       # falls back to SECRET if empty; set in prod (openssl rand -hex 64)
JWT_ISSUER=rails.zoracle
JWT_AUDIENCE=rails.zoracle.clients
JWT_ACCESS_LIFESPAN=15                 # minutes
JWT_REFRESH_LIFESPAN=10080             # minutes (7d)
PASSWORD_RESET_LIFESPAN=15             # minutes
EMAIL_VERIFICATION_LIFESPAN=1440       # minutes (24h)
HMAC_TIMESTAMP_AGE=5                   # minutes
ADMIN_API_TOKEN=                       # empty disables admin endpoints
GOOGLE_OAUTH_CLIENT_ID=

# ── Database (Postgres) ──
# Preferred: a full connection string (Neon/Railway/Heroku give you one, with
# sslmode=require baked in). When set, it overrides the DB_* parts below.
DATABASE_URL=                          # e.g. postgresql://user:pass@host/db?sslmode=require
# Discrete parts — used only when DATABASE_URL is empty (local dev).
DB_NAME=rails
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
SSL_MODE=disable                       # local default; managed DBs need require (use DATABASE_URL)

# ── Redis ──
# Preferred: full connection string (Railway/Upstash). Overrides the parts below.
REDIS_URL=                              # e.g. redis://default:pass@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Frontend URLs ──
CHECKOUT_BASE_URL=https://checkout.zoracle.com
PWA_BASE_URL=https://tapp.zoracle.com

# ── Email (Resend / SendGrid / Mailgun) ──
EMAIL_PROVIDER=resend                  # resend | sendgrid | mailgun
EMAIL_DOMAIN=api.sendgrid.com
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=Rails <no-reply@usezoracle.com>
CARD_RECOVERY_SENDGRID_TEMPLATE=

# ── Identity / KYC (Smile Identity) ──
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_BASE_URL=https://testapi.smileidentity.com   # [testnet]
# SMILE_IDENTITY_BASE_URL=https://api.smileidentity.com     # [mainnet]

# ── Order lifecycle ──
ORDER_FULFILLMENT_VALIDITY=10          # minutes
RECEIVE_ADDRESS_VALIDITY=30            # minutes
ORDER_REQUEST_VALIDITY=120             # seconds
BUCKET_QUEUE_REBUILD_INTERVAL=1        # minutes
REFUND_CANCELLATION_COUNT=3
PERCENT_DEVIATION_FROM_EXTERNAL_RATE=1
PERCENT_DEVIATION_FROM_MARKET_RATE=10
NETWORK_FEE=0.05

# ── Sui ──
SUI_AGGREGATOR_PRIVATE_KEY=            # secret: Ed25519 seed, hex, no 0x (same key all networks)
SUI_AGGREGATOR_CAP_ID=                 # per-deployment
SUI_GATEWAY_PACKAGE_ID=                # per-deployment
SUI_GATEWAY_OBJECT_ID=                 # per-deployment
SUI_GRPC_TOKEN=                        # optional x-token for the gRPC/WS provider
SUI_RPC_URL=https://fullnode.testnet.sui.io:443     # [testnet]
SUI_WS_URL=wss://fullnode.testnet.sui.io:443        # [testnet]
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443    # [testnet]
# SUI_RPC_URL=https://fullnode.mainnet.sui.io:443   # [mainnet]
# SUI_WS_URL=wss://fullnode.mainnet.sui.io:443      # [mainnet]
# SUI_GRPC_URL=https://fullnode.mainnet.sui.io:443  # [mainnet]

# ── Sui gas station (Shinami) ──
SHINAMI_GAS_BASE_URL=                   # from Shinami dashboard
SHINAMI_GAS_API_KEY=                    # network-specific key (separate for testnet / mainnet)

# ── Route A: LiFi bridge (Sui → Base) ──
LIFI_BASE_URL=https://li.quest/v1
LIFI_API_KEY=                          # optional; free tier rate-limited

# ── Route A: Base EVM ──
BASE_AGGREGATOR_ADDRESS=               # our Base hot wallet (receives bridged USDC, signs createOrder)
BASE_SIGNER_KEY=                       # secret: hex private key for the aggregator wallet
BASE_USDC_DECIMALS=6
BASE_SENDER_FEE_BPS=50                  # bps; 50 = 0.5%
BASE_NATIVE_LOW_THRESHOLD_WEI=10000000000000000   # 0.01 ETH; low-balance alert threshold
BASE_CHAIN_ID=84532                                          # [testnet] Base Sepolia
BASE_RPC_URL=https://sepolia.base.org                       # [testnet]
BASE_USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e   # [testnet]
BASE_GATEWAY_CONTRACT=0x847dfdAa218F9137229CF8424378871A1DA8f625 # [testnet]
# BASE_CHAIN_ID=8453                                         # [mainnet] Base
# BASE_RPC_URL=https://mainnet.base.org                      # [mainnet]
# BASE_USDC_CONTRACT=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913    # [mainnet]
# BASE_GATEWAY_CONTRACT=0x30f6a8457f8e42371e204a9c103f2bd42341dd0f # [mainnet]

# ── Settlement aggregator (Paycrest) ──
SETTLEMENT_API_URL=https://api.paycrest.io
SETTLEMENT_SENDER_API_KEY_ID=          # UUID identifying this sender
SETTLEMENT_PUBKEY_CACHE_TTL_SECONDS=3600
SETTLEMENT_POLL_INTERVAL_SECONDS=30

# ── Aggregator RSA keypair (encrypts recipient bank details carried on-chain) ──
AGGREGATOR_PUBLIC_KEY=                  # secret
AGGREGATOR_PRIVATE_KEY=                 # secret

# ── BaaS rail (NGN payouts) ──
# Selects the Banking-as-a-Service provider behind the baas adapter. Today only
# "safehaven" is implemented; add a case in main.go initBaaSRail() to add more.
BAAS_PROVIDER=safehaven

# ── Safe Haven (BaaS / NGN payouts: Route B sub-accounts + Route C float) ──
SAFEHAVEN_CLIENT_ID=
SAFEHAVEN_PRIVATE_KEY=                  # secret: RSA PEM, newlines as \n
SAFEHAVEN_DEBIT_ACCOUNT_NUMBER=        # funded account that payouts debit
SAFEHAVEN_WEBHOOK_SECRET=              # HMAC-SHA256; empty skips verification (dev only)
# Max single admin payout (NGN) — fat-finger / stolen-token guard. 0 = unlimited.
SAFEHAVEN_MAX_TRANSFER_NGN=1000000
SAFEHAVEN_AUDIENCE=                    # optional, default = base url
SAFEHAVEN_ISSUER=                      # optional, default = client id
SAFEHAVEN_BASE_URL=https://api.safehavenmfb.com            # [mainnet]
# SAFEHAVEN_BASE_URL=https://api.sandbox.safehavenmfb.com  # [sandbox]

# ── Platform (auto-injected; rarely set manually) ──
# PORT=                                # listen port; set by Railway/Heroku, overrides SERVER_PORT
# ENV_FILE_PATH=.env                   # alternate config filename for startup
