# =============================================================================
# Rails — example environment configuration
# Copy to .env and fill in real values. Never commit .env.
# Real secrets (RSA keys, mnemonics, API keys, signer keys) MUST NOT be
# committed here. The .env.example is checked in; the .env is gitignored.
# =============================================================================

# --- Server ---
SECRET=<a-random-32-byte-secret-used-for-AES-encryption-and-HMAC>
DEBUG=True
ALLOWED_HOSTS=0.0.0.0
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_TIMEZONE=Africa/Lagos

# --- Auth ---
JWT_SIGNING_KEY=                           # SEPARATE from SECRET. `openssl rand -hex 64`.
                                           # Falls back to SECRET if unset (dev only — set in prod).
JWT_ISSUER=rails.zoracle                   # iss claim — anchors tokens to this deployment
JWT_AUDIENCE=rails.zoracle.clients         # aud claim
JWT_ACCESS_LIFESPAN=15                     # minutes — short-lived stateless access token
JWT_REFRESH_LIFESPAN=10080                 # minutes (7d) — stateful opaque refresh, rotated on use
PASSWORD_RESET_LIFESPAN=15                 # minutes — short by design
EMAIL_VERIFICATION_LIFESPAN=1440           # minutes (24h) — long enough to survive an email lag
HMAC_TIMESTAMP_AGE=5                       # minutes
ENVIRONMENT=local                          # local, staging, production
SENTRY_DSN=
HOST_DOMAIN=http://localhost:8000

# Public URL of the Zoracle checkout web app — Tapp Merchant embeds
# `<CHECKOUT_BASE_URL>/order/<order_id>` in NDEF / QR for payers.
CHECKOUT_BASE_URL=https://checkout.zoracle.com

# Public URL of the Tapp PWA (cardholder side). /c/:token redirects
# here for card linking + dashboard + resync.
PWA_BASE_URL=https://tapp.zoracle.com

# Shared secret for admin-only endpoints (PoC: card issue-batch).
# Generate via `openssl rand -hex 32`. Leave empty to disable
# admin endpoints entirely.
ADMIN_API_TOKEN=

# Google OAuth client ID — used by /v1/auth/google to verify ID
# tokens posted by the Tapp PWA. Same client ID is also set on the
# PWA side as NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID. Get from Google
# Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
GOOGLE_OAUTH_CLIENT_ID=

# settlement API URL — used to live-fetch supported institutions.
SETTLEMENT_API_URL=https://api.paycrest.io

# --- Database ---
DB_NAME=rails
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
SSL_MODE=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Order lifecycle ---
ORDER_FULFILLMENT_VALIDITY=10              # minutes
RECEIVE_ADDRESS_VALIDITY=30                # minutes
ORDER_REQUEST_VALIDITY=120                 # seconds
BUCKET_QUEUE_REBUILD_INTERVAL=1            # minutes
REFUND_CANCELLATION_COUNT=3
PERCENT_DEVIATION_FROM_EXTERNAL_RATE=1
PERCENT_DEVIATION_FROM_MARKET_RATE=10

# ============================================================================
# Sui network — uncomment EXACTLY ONE block, comment the other.
# Aggregator private key is the same across networks (the derived address
# just has independent balances per network). The Gateway / Cap object
# IDs are network-specific: each deployment creates fresh objects.
# Restart the Rails server after switching.
# ============================================================================

# --- Sui testnet ---
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GATEWAY_PACKAGE_ID=                    # fill after `sui client publish` on testnet
SUI_GATEWAY_OBJECT_ID=                     # shared rails::config::Gateway object on testnet
SUI_AGGREGATOR_CAP_ID=                     # AggregatorCap minted on testnet

# --- Sui mainnet ---
# SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
# SUI_WS_URL=                              # wss:// endpoint for event subscriptions (e.g. wss://sui-mainnet.blockvision.org/v1/<KEY>)
# SUI_GATEWAY_PACKAGE_ID=
# SUI_GATEWAY_OBJECT_ID=
# SUI_AGGREGATOR_CAP_ID=

# Aggregator signer — Ed25519 seed, hex (no 0x prefix). Same on all
# networks; faucet the derived address separately on each one before use.
SUI_AGGREGATOR_PRIVATE_KEY=

# --- Route A: LiFi cross-chain bridge (Sui → Base) ---
LIFI_BASE_URL=https://li.quest/v1
LIFI_API_KEY=                              # optional; free tier rate-limited. Get one at https://li.quest

# ============================================================================
# Base network (Route A: Sui USDC → Base USDC → fiat off-ramp).
# Independent from the Sui toggle — you can run Sui testnet + Base mainnet
# or any combination. Uncomment EXACTLY ONE Base block.
# Signer key is the same across networks; balances are per-network.
# ============================================================================

BASE_AGGREGATOR_ADDRESS=                   # our Base hot wallet — receives bridged USDC; signs createOrder
BASE_SIGNER_KEY=                           # hex private key (0x optional) for the aggregator wallet —
                                           # signs USDC.approve + Gateway.createOrder. KEEP SECRET.
                                           # Generate one-off + chmod 0600 — never commit.
BASE_USDC_DECIMALS=6                       # 6 on both mainnet and sepolia for Circle native USDC

# --- Base mainnet (chain 8453) ---
# BASE_CHAIN_ID=8453
# BASE_RPC_URL=https://mainnet.base.org
# BASE_GATEWAY_CONTRACT=0x30f6a8457f8e42371e204a9c103f2bd42341dd0f
# BASE_USDC_CONTRACT=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913

# --- Base Sepolia (chain 84532) ---
BASE_CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
BASE_GATEWAY_CONTRACT=0x847dfdAa218F9137229CF8424378871A1DA8f625
BASE_USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e

BASE_SENDER_FEE_BPS=50                     # sender fee skimmed on each order, in bps. 50 = 0.5%
BASE_NATIVE_LOW_THRESHOLD_WEI=10000000000000000  # 0.01 ETH; below this the low-balance cron alerts ops

# --- settlement aggregator ---
SETTLEMENT_PUBKEY_CACHE_TTL_SECONDS=3600   # how long to cache the RSA pubkey before refetch
SETTLEMENT_SENDER_API_KEY_ID=              # UUID identifying this sender for analytics + LP attribution.
                                           # Register at https://paycrest.io for a real key. Any UUID works
                                           # for v1 (off-ramp doesn't authenticate the API key — it's metadata
                                           # inside the encrypted messageHash blob).
SETTLEMENT_POLL_INTERVAL_SECONDS=30        # cadence of advanceDispatching status polling

# --- Aggregator RSA keypair (encrypts/decrypts recipient bank details that
#     travel on-chain in the OrderCreated message_hash field). Distinct from
#     SUI_AGGREGATOR_PRIVATE_KEY (Ed25519, signs Sui txs).
#
#     Generate fresh with:
#       openssl genrsa -out aggregator.pem 2048
#       openssl rsa -in aggregator.pem -pubout -out aggregator.pub.pem
#     NEVER commit real keys.
AGGREGATOR_PUBLIC_KEY=
AGGREGATOR_PRIVATE_KEY=

# --- Email / notifications ---
EMAIL_DOMAIN=api.sendgrid.com
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# SendGrid dynamic-template ID for the Tap Card iOS-recovery email.
# Empty → AdminRecovery endpoint logs the code instead of emailing.
# Template should accept one variable: {{recovery_code}}.
CARD_RECOVERY_SENDGRID_TEMPLATE=

# --- Identity / KYC ---
SMILE_IDENTITY_BASE_URL=https://testapi.smileidentity.com
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=
