# =============================================================================
# Rails — example environment configuration
# Copy to .env and fill in real values. Never commit .env.
# Real secrets (RSA keys, mnemonics, API keys) MUST NOT be committed here.
# =============================================================================

# --- Server ---
SECRET=<a-random-32-byte-secret-used-for-AES-encryption-and-HMAC>
DEBUG=True
ALLOWED_HOSTS=0.0.0.0
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_TIMEZONE=Africa/Lagos
JWT_ACCESS_LIFESPAN=15                     # minutes
JWT_REFRESH_LIFESPAN=10080                 # minutes
PASSWORD_RESET_LIFESPAN=5                  # minutes
HMAC_TIMESTAMP_AGE=5                       # minutes
ENVIRONMENT=local                          # local, staging, production
SENTRY_DSN=
HOST_DOMAIN=http://localhost:8000

# Public URL of the Zoracle checkout web app — Tapp Merchant embeds
# `<CHECKOUT_BASE_URL>/order/<order_id>` in NDEF / QR for payers.
CHECKOUT_BASE_URL=https://checkout.zoracle.com

# Public URL of the Tapp PWA (cardholder side). /c/:token redirects
# here for card linking + dashboard + resync.
PWA_BASE_URL=https://tapp.zoracle.com

# Shared secret for admin-only endpoints (PoC: card issue-batch).
# Generate via `openssl rand -hex 32`. Leave empty to disable
# admin endpoints entirely.
ADMIN_API_TOKEN=

# Google OAuth client ID — used by /v1/auth/google to verify ID
# tokens posted by the Tapp PWA. Same client ID is also set on the
# PWA side as NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID. Get from Google
# Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
GOOGLE_OAUTH_CLIENT_ID=

# Paycrest API URL — used to live-fetch supported institutions.
PAYCREST_API_URL=https://api.paycrest.io

# --- Database ---
DB_NAME=rails
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
SSL_MODE=disable

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Order lifecycle ---
ORDER_FULFILLMENT_VALIDITY=10              # minutes
RECEIVE_ADDRESS_VALIDITY=30                # minutes
ORDER_REQUEST_VALIDITY=120                 # seconds
BUCKET_QUEUE_REBUILD_INTERVAL=1            # minutes
REFUND_CANCELLATION_COUNT=3
PERCENT_DEVIATION_FROM_EXTERNAL_RATE=1
PERCENT_DEVIATION_FROM_MARKET_RATE=10

# --- Sui chain ---
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GATEWAY_PACKAGE_ID=                    # set after `sui client publish`
SUI_GATEWAY_OBJECT_ID=                     # the shared rails::config::Gateway object ID
SUI_AGGREGATOR_CAP_ID=                     # AggregatorCap owned by the backend wallet
SUI_AGGREGATOR_PRIVATE_KEY=                # 32-byte Ed25519 seed, hex-encoded (NO 0x prefix)

# --- Route A: LiFi cross-chain bridge (Sui → BSC) ---
LIFI_BASE_URL=https://li.quest/v1
LIFI_API_KEY=                              # optional; free tier rate-limited. Get one at https://li.quest
BSC_RPC_URL=https://bsc-dataseed.bnbchain.org
BSC_AGGREGATOR_ADDRESS=                    # our BSC hot wallet (receives bridged USDC)
BSC_GATEWAY_CONTRACT=                      # existing EVM Gateway address (used by mode=lp dispatch)

# --- Aggregator RSA keypair (encrypts/decrypts recipient bank details that
#     travel on-chain in the OrderCreated message_hash field). Distinct from
#     SUI_AGGREGATOR_PRIVATE_KEY (Ed25519, signs Sui txs).
#
#     Generate fresh with:
#       openssl genrsa -out aggregator.pem 2048
#       openssl rsa -in aggregator.pem -pubout -out aggregator.pub.pem
#     NEVER commit real keys.
AGGREGATOR_PUBLIC_KEY=
AGGREGATOR_PRIVATE_KEY=

# --- Email / notifications ---
EMAIL_DOMAIN=api.sendgrid.com
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=

# SendGrid dynamic-template ID for the Tap Card iOS-recovery email.
# Empty → AdminRecovery endpoint logs the code instead of emailing.
# Template should accept one variable: {{recovery_code}}.
CARD_RECOVERY_SENDGRID_TEMPLATE=

# --- Identity / KYC ---
SMILE_IDENTITY_BASE_URL=https://testapi.smileidentity.com
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=
